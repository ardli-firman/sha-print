<Page x:Class="ShaPrint.WpfApp.Views.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="WelcomePage"
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Welcome to ShaPrint" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Select an operation mode:" FontSize="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <ui:Button Appearance="Primary" Content="RUN AS SERVER" 
                       Icon="{ui:SymbolIcon Server24}"
                       Command="{Binding ViewModel.SelectServerModeCommand}"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                       Padding="20,15" FontSize="16" />
            <TextBlock Text="Host your local printers to the network." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="10,5,0,20"/>

            <ui:Button Appearance="Secondary" Content="RUN AS CLIENT" 
                       Icon="{ui:SymbolIcon Desktop24}"
                       Command="{Binding ViewModel.SelectClientModeCommand}"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                       Padding="20,15" FontSize="16" />
            <TextBlock Text="Connect and print to a ShaPrint Server." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="10,5,0,0"/>
        </StackPanel>
    </Grid>
</Page>
