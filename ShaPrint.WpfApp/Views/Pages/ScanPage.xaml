<Page x:Class="ShaPrint.WpfApp.Views.Pages.ScanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Remote Scan"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="24,20,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" MinWidth="260"/> <!-- Left Panel: Settings, Logs, Discovery -->
            <ColumnDefinition Width="20"/>  <!-- Spacer -->
            <ColumnDefinition Width="5*" MinWidth="300"/> <!-- Right Panel: Preview -->
        </Grid.ColumnDefinitions>

        <!-- Left Column: Controls & Logs -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Header -->
                <RowDefinition Height="Auto"/> <!-- 1: Search Server Card -->
                <RowDefinition Height="Auto"/> <!-- 2: Available Scanners Label -->
                <RowDefinition Height="*"/>    <!-- 3: Remote Scanner ListBox -->
                <RowDefinition Height="Auto"/> <!-- 4: Scan Parameters Settings Card -->
                <RowDefinition Height="Auto"/> <!-- 5: Log Label -->
                <RowDefinition Height="90"/>   <!-- 6: Logs TextBox -->
                <RowDefinition Height="Auto"/> <!-- 7: Progress Bar -->
            </Grid.RowDefinitions>

            <!-- Header (top) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Remote Document Scan" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Discover remote scanner servers and scan documents." 
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" FontSize="11"/>
            </StackPanel>

            <!-- Network Discovery Card (top) -->
            <ui:Card Grid.Row="1" Margin="0,0,0,8" Padding="10">
                <StackPanel>
                    <TextBlock Text="Scanner Server Search" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Server IP:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                        <ui:TextBox Grid.Column="1" Text="{Binding ViewModel.TargetIp, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="e.g. 192.168.1.50 (blank = auto-discovery)"/>
                        
                        <ui:Button Grid.Column="2" Content="Scan LAN" Margin="6,0,0,0"
                                   Command="{Binding ViewModel.ScanLanCommand}"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Search24}" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Available Remote Scanners Label -->
            <TextBlock Grid.Row="2" Text="Available Remote Scanners" Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <!-- Discovered Scanners List -->
            <ListBox Grid.Row="3" ItemsSource="{Binding ViewModel.DiscoveredScanners}" 
                     SelectedItem="{Binding ViewModel.SelectedScanner, Mode=TwoWay}"
                     BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                     MinHeight="60"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,4"/>
                        <Setter Property="MinHeight" Value="28"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2,1">
                            <ui:SymbolIcon Symbol="Scan24" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Settings Card (Sticky above logs) -->
            <ui:Card Grid.Row="4" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Scan Parameters" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="12"/>
                    
                    <!-- DPI -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Resolution (DPI):" VerticalAlignment="Center" FontSize="11"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ViewModel.DpiOptions}" SelectedItem="{Binding ViewModel.SelectedDpi}"/>
                    </Grid>

                    <!-- Color Mode -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Color Mode:" VerticalAlignment="Center" FontSize="11"/>
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding ViewModel.SelectedColorMode}">
                            <ComboBoxItem Content="Black &amp; White"/>
                            <ComboBoxItem Content="Grayscale"/>
                            <ComboBoxItem Content="Full Color"/>
                        </ComboBox>
                    </Grid>

                    <!-- Output Format -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="File Format:" VerticalAlignment="Center" FontSize="11"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ViewModel.FormatOptions}" SelectedItem="{Binding ViewModel.SelectedFormat}"/>
                    </Grid>

                    <!-- Brightness -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Brightness:" VerticalAlignment="Center" FontSize="11"/>
                        <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding ViewModel.Brightness}" 
                                AutoToolTipPlacement="BottomRight" TickFrequency="10" IsSnapToTickEnabled="False" />
                    </Grid>

                    <!-- Contrast -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Contrast:" VerticalAlignment="Center" FontSize="11"/>
                        <Slider Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding ViewModel.Contrast}" 
                                AutoToolTipPlacement="BottomRight" TickFrequency="10" IsSnapToTickEnabled="False" />
                    </Grid>

                    <!-- Trigger Scan -->
                    <ui:Button Command="{Binding ViewModel.PerformScanCommand}"
                               Content="Scan Now"
                               Appearance="Success"
                               HorizontalAlignment="Stretch"
                               Icon="{ui:SymbolIcon Play24}"
                               IsEnabled="{Binding ViewModel.IsPerformingScan, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                </StackPanel>
            </ui:Card>

            <!-- Activity Log Label -->
            <TextBlock Grid.Row="5" Text="Activity Log (Scan):" Margin="0,0,0,3" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11"/>

            <!-- Logs TextBox -->
            <TextBox Grid.Row="6" Text="{Binding ViewModel.LogsText, Mode=OneWay}" 
                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                     FontFamily="Consolas" FontSize="10"
                     BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Margin="0,0,0,6"/>

            <!-- Progress bar and status -->
            <Grid Grid.Row="7" Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ViewModel.StatusText}" VerticalAlignment="Center" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,8,0" FontSize="11"/>
                    <ui:ProgressRing IsIndeterminate="True" Width="14" Height="14" 
                                     Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource BoolToVis}}"/>
                    <ui:ProgressRing IsIndeterminate="True" Width="14" Height="14" 
                                     Visibility="{Binding ViewModel.IsPerformingScan, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Right Column: Document Preview Pane -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Preview Header & Zoom controls -->
                <RowDefinition Height="*"/>    <!-- Scrollable Preview Image -->
            </Grid.RowDefinitions>

            <!-- Header with Zoom Controls -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Document Preview" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                
                <!-- Zoom Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding ViewModel.HasScannedFile, Converter={StaticResource BoolToVis}}">
                    <ui:Button Content="-" Command="{Binding ViewModel.ZoomOutCommand}" CommandParameter="{Binding ElementName=PreviewScrollViewer}" Padding="8,2" Margin="0,0,4,0" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ViewModel.ZoomPercentText}" FontSize="11" VerticalAlignment="Center" Margin="4,0" Width="40" TextAlignment="Center"/>
                    <ui:Button Content="+" Command="{Binding ViewModel.ZoomInCommand}" CommandParameter="{Binding ElementName=PreviewScrollViewer}" Padding="8,2" Margin="4,0,0,0" FontSize="10" FontWeight="Bold"/>
                    <ui:Button Content="Fit" Command="{Binding ViewModel.ZoomFitCommand}" Padding="10,2" Margin="8,0,0,0" FontSize="10" Appearance="Secondary"/>
                    <ui:Button Content="Rotate" Command="{Binding ViewModel.RotateCommand}" Padding="10,2" Margin="8,0,0,0" FontSize="10" Appearance="Secondary" Icon="{ui:SymbolIcon ArrowClockwise24}"/>
                </StackPanel>
            </Grid>
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="12"/> <!-- Spacer -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Thumbnail Sidebar -->
                <Grid Grid.Column="0" Visibility="{Binding ViewModel.HasScannedFile, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" 
                             ItemsSource="{Binding ViewModel.ScannedPages}" 
                             SelectedItem="{Binding ViewModel.SelectedPage, Mode=TwoWay}"
                             BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="1"/>
                                <Setter Property="Margin" Value="0,3"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" CornerRadius="2" Padding="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid>
                                        <Image Source="{Binding PreviewSource}" Height="80" Width="60" Stretch="Uniform" />
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="#CC000000" CornerRadius="2" Padding="2,1">
                                            <TextBlock Text="{Binding Format}" Foreground="White" FontSize="7" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Content="▲" Padding="2" Command="{Binding ViewModel.MovePageUpCommand}" HorizontalAlignment="Stretch" FontSize="10" />
                            <ui:Button Grid.Column="1" Content="▼" Padding="2" Command="{Binding ViewModel.MovePageDownCommand}" HorizontalAlignment="Stretch" Margin="4,0,0,0" FontSize="10" />
                        </Grid>
                        <ui:Button Content="Delete" Appearance="Danger" Command="{Binding ViewModel.DeletePageCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,4" FontSize="10" Padding="0,4"/>
                        <ui:Button Content="Clear" Appearance="Secondary" Command="{Binding ViewModel.ClearQueueCommand}" HorizontalAlignment="Stretch" FontSize="10" Padding="0,4"/>
                    </StackPanel>
                </Grid>

                <!-- Main Preview image -->
                <Grid Grid.Column="2">
                    <Border BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
                        <Grid>
                            <!-- Empty State -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20"
                                        Visibility="{Binding ViewModel.EmptyStateVisibility}">
                                <ui:SymbolIcon Symbol="Document24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="No document scanned yet." Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Loading State -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20"
                                        Visibility="{Binding ViewModel.LoadingStateVisibility}">
                                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,16"/>
                                <TextBlock Text="Scanning Document..." FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Acquiring page from remote scanner..." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Image Preview -->
                            <ScrollViewer x:Name="PreviewScrollViewer"
                                          VerticalScrollBarVisibility="{Binding ViewModel.ScrollBarVisibilitySetting}"
                                          HorizontalScrollBarVisibility="{Binding ViewModel.ScrollBarVisibilitySetting}"
                                          Visibility="{Binding ViewModel.ImagePreviewVisibility}"
                                          PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel">
                                <Image Source="{Binding ViewModel.PreviewImage}" Margin="8" Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.LayoutTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding ViewModel.CurrentScale}" ScaleY="{Binding ViewModel.CurrentScale}"/>
                                            <RotateTransform Angle="{Binding ViewModel.RotationAngle}"/>
                                        </TransformGroup>
                                    </Image.LayoutTransform>
                                </Image>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    
                    <!-- Save Button (Float / Overlay in bottom-right if file exists) -->
                    <ui:Button Content="Save File As..." Appearance="Primary"
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveAsCommand}"
                               Visibility="{Binding ViewModel.HasScannedFile, Converter={StaticResource BoolToVis}}"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
