<Page x:Class="ShaPrint.WpfApp.Views.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Client Dashboard">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <DockPanel Margin="24,20,24,16" LastChildFill="True">

        <!-- Header (top) -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Client Dashboard" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Discover and install network printers." 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Network Discovery Card (top, compact) -->
        <ui:Card DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Network Discovery" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="13"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Server IP:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <ui:TextBox Grid.Column="1" Text="{Binding ViewModel.TargetIp, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="e.g. 192.168.1.50 (blank = auto)"/>
                    
                    <ui:Button Grid.Column="2" Content="Scan" Margin="8,0,0,0"
                               Command="{Binding ViewModel.ScanCommand}"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Search24}" />
                </Grid>
                
                <TextBlock Text="Hint: If Server is on a different VLAN, enter its IP explicitly." 
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </ui:Card>

        <!-- Controls bar (bottom) -->
        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ViewModel.StatusText}" VerticalAlignment="Center" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,10,0"/>
                <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" 
                                 Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <ui:Button Grid.Column="1" Margin="0,0,8,0"
                       Command="{Binding ViewModel.DeleteSelectedCommand}"
                       Content="Delete" Appearance="Danger"
                       Icon="{ui:SymbolIcon Delete24}"/>

            <ui:Button Grid.Column="2" 
                       Command="{Binding ViewModel.InstallSelectedCommand}"
                       Content="Install" Appearance="Success"
                       Icon="{ui:SymbolIcon ArrowDownload24}"/>
        </Grid>

        <!-- Activity Log label (bottom) -->
        <TextBlock DockPanel.Dock="Bottom" Text="Activity Log:" Margin="0,10,0,3" 
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>

        <!-- Activity Log (bottom, compact) -->
        <ListBox DockPanel.Dock="Bottom" ItemsSource="{Binding ViewModel.Logs}" 
                 FontFamily="Consolas" FontSize="11" Height="110"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,1"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Printer List (fills remaining space, compact items) -->
        <ListBox ItemsSource="{Binding ViewModel.DiscoveredPrinters}" 
                 SelectedItem="{Binding ViewModel.SelectedPrinter, Mode=TwoWay}"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <ui:SymbolIcon Symbol="Print24" Margin="0,0,8,0" FontSize="14"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="13"/>
                        <Border Background="{DynamicResource SystemFillColorSuccessBrush}" 
                                CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Installed" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Page>
