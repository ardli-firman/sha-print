<Page x:Class="ShaPrint.WpfApp.Views.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Printer Setup">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid ClipToBounds="True">
        <!-- Background Ornaments -->
        <Ellipse Width="200" Height="200" Fill="#E0F7FA" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-60" IsHitTestVisible="False" Opacity="0.5"/>
        <Ellipse Width="160" Height="160" Fill="#EDF2FF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-40,-40,0,0" IsHitTestVisible="False" Opacity="0.5"/>
        <Ellipse Width="20" Height="20" Fill="#E0F7FA" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="50,0,0,80" IsHitTestVisible="False" Opacity="0.5"/>
        <Ellipse Width="24" Height="24" Fill="#DBEAFE" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,60,50,0" IsHitTestVisible="False" Opacity="0.4"/>

        <!-- Themed icon ornaments -->
        <ui:SymbolIcon Symbol="Print24" FontSize="44" Foreground="#0891B2" Opacity="0.04" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30,0,0,30" IsHitTestVisible="False"/>
        <ui:SymbolIcon Symbol="Desktop24" FontSize="50" Foreground="#0891B2" Opacity="0.04" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,25,25,0" IsHitTestVisible="False"/>
        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="30" Foreground="#0052CC" Opacity="0.04" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0" IsHitTestVisible="False"/>

        <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Card -->
            <RowDefinition Height="3*"/>   <!-- Printer List -->
            <RowDefinition Height="Auto"/> <!-- Controls bar -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="Auto"/> <!-- Log label -->
            <RowDefinition Height="2*"/>   <!-- Logs -->
        </Grid.RowDefinitions>

        <!-- Header (top) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Printer Setup" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Discover and install network printers." 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Network Discovery Card (top, compact) -->
        <ui:Card Grid.Row="1" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Network Discovery" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="13"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Server IP:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <ui:TextBox Grid.Column="1" Text="{Binding ViewModel.TargetIp, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="e.g. 192.168.1.50 (blank = auto)"/>
                    
                    <ui:Button Grid.Column="2" Content="Scan" Margin="8,0,0,0"
                               Command="{Binding ViewModel.ScanCommand}"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Search24}" />
                </Grid>
                
                <TextBlock Text="Hint: If Server is on a different VLAN, enter its IP explicitly." 
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </ui:Card>

        <!-- Printer List (fills remaining space, compact items) -->
        <ListBox Grid.Row="2" ItemsSource="{Binding ViewModel.DiscoveredPrinters}" 
                 SelectedItem="{Binding ViewModel.SelectedPrinter, Mode=TwoWay}"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <ui:SymbolIcon Symbol="Print24" Margin="0,0,8,0" FontSize="14"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="13"/>
                        <Border Background="{DynamicResource SystemFillColorSuccessBrush}" 
                                CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Installed" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Controls bar (bottom) -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ViewModel.StatusText}" VerticalAlignment="Center" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,10,0"/>
                <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" 
                                 Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <ui:Button Grid.Column="1" Margin="0,0,8,0"
                       Command="{Binding ViewModel.DeleteSelectedCommand}"
                       Content="Delete" Appearance="Danger"
                       Icon="{ui:SymbolIcon Delete24}"/>

            <ui:Button Grid.Column="2" 
                       Command="{Binding ViewModel.InstallSelectedCommand}"
                       Content="Install" Appearance="Success"
                       Icon="{ui:SymbolIcon ArrowDownload24}"/>
        </Grid>

        <!-- Activity Log label (bottom) -->
        <GridSplitter Grid.Row="4" Height="5" HorizontalAlignment="Stretch" Background="Transparent" Margin="0,5"/>

        <TextBlock Grid.Row="5" Text="Activity Log (Resizable &amp; Copyable):" Margin="0,0,0,3" 
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>

        <!-- Activity Log (bottom, compact) -->
        <TextBox Grid.Row="6" Text="{Binding ViewModel.LogsText, Mode=OneWay}" 
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                 FontFamily="Consolas" FontSize="11"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />

    </Grid>
    </Grid>
</Page>
