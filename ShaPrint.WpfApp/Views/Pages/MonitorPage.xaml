<Page x:Class="ShaPrint.WpfApp.Views.Pages.MonitorPage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"

      xmlns:converters="clr-namespace:ShaPrint.WpfApp.Converters"

      Title="Server Monitoring">



    <Page.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <converters:IntToVisibilityConverter x:Key="IntToVis" />

        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <converters:StatusToBrushConverter x:Key="StatusToBrush" />

        <converters:StatusToTextBrushConverter x:Key="StatusToTextBrush" />

        <converters:StatusToDotBrushConverter x:Key="StatusToDotBrush" />



        <!-- Stat Card padding style -->

        <Style x:Key="StatCard" TargetType="ui:CardAction" BasedOn="{StaticResource {x:Type ui:CardAction}}">

            <Setter Property="Padding" Value="14,12"/>

            <Setter Property="Margin" Value="0,0,12,0"/>

            <Setter Property="IsChevronVisible" Value="False"/>

        </Style>



        <!-- Tab Control -->

        <Style TargetType="TabControl">

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Padding" Value="0,8,0,0"/>

        </Style>



        <!-- Tab Item with custom pill template -->

        <Style TargetType="TabItem">

            <Setter Property="FontSize" Value="12.5"/>

            <Setter Property="FontWeight" Value="Medium"/>

            <Setter Property="Padding" Value="14,7"/>

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TabItem">

                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Margin="0,0,4,0"

                                Background="Transparent" CornerRadius="6">

                            <ContentPresenter ContentSource="Header"

                                              HorizontalAlignment="Center"

                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsSelected" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>

                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>

                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- Tab content panel — wraps each DataGrid -->

        <Style x:Key="TabContentPanel" TargetType="Border">

            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>

            <Setter Property="CornerRadius" Value="8"/>

            <Setter Property="MinHeight" Value="100"/>

            <Setter Property="Margin" Value="0,4,0,0"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="BorderBrush" Value="#E5E7EB"/>

        </Style>



        <!-- Shadcn row style: transparent bg, hover highlight, no borders -->

        <Style x:Key="ShadcnRowStyle" TargetType="DataGridRow">

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="MinHeight" Value="32"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">

                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>

                </Trigger>

            </Style.Triggers>

        </Style>



        <!-- Shadcn header style: muted, semi-bold, thin bottom border -->

        <Style x:Key="ShadcnHeaderStyle" TargetType="DataGridColumnHeader">

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="FontSize" Value="11"/>

            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>

            <Setter Property="BorderThickness" Value="0,0,0,1"/>

            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>

            <Setter Property="Padding" Value="16,10"/>

            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="VerticalContentAlignment" Value="Center"/>

        </Style>



        <!-- ─── Shadcn-style DataGrid: flat, clean, no grid lines, row hover, muted headers ─── -->

        <Style x:Key="TabDataGrid" TargetType="ui:DataGrid">

            <Setter Property="AutoGenerateColumns" Value="False"/>

            <Setter Property="IsReadOnly" Value="True"/>

            <Setter Property="HeadersVisibility" Value="Column"/>

            <Setter Property="SelectionMode" Value="Single"/>

            <Setter Property="SelectionUnit" Value="Cell"/>

            <Setter Property="CanUserResizeRows" Value="False"/>

            <Setter Property="CanUserDeleteRows" Value="False"/>

            <Setter Property="CanUserReorderColumns" Value="False"/>

            <Setter Property="CanUserSortColumns" Value="True"/>

            <Setter Property="GridLinesVisibility" Value="None"/>

            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>

            <Setter Property="RowHeaderWidth" Value="0"/>

            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>

            <Setter Property="RowStyle" Value="{StaticResource ShadcnRowStyle}"/>

            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ShadcnHeaderStyle}"/>

        </Style>



        <!-- TextBlock style applied inside every DataGridTextColumn (guarantees cell padding) -->

        <Style x:Key="CellTextStyle" TargetType="TextBlock">

            <Setter Property="Margin" Value="16,0"/>

            <Setter Property="VerticalAlignment" Value="Center"/>

            <Setter Property="FontSize" Value="11.5"/>

        </Style>



        <!-- ─── Flat cell style: global font, wider padding, copy context ─── -->

        <Style x:Key="ShadcnCellStyle" TargetType="DataGridCell">

            <Setter Property="FontSize" Value="11.5"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="VerticalAlignment" Value="Stretch"/>

            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>

            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="ContextMenu">

                <Setter.Value>

                    <ContextMenu>

                        <MenuItem Header="Copy Cell" Command="ApplicationCommands.Copy"

                                  InputGestureText="Ctrl+C">

                            <MenuItem.Icon>

                                <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>

                            </MenuItem.Icon>

                        </MenuItem>

                    </ContextMenu>

                </Setter.Value>

            </Setter>

            <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridCell_PreviewMouseRightButtonDown"/>

            <Style.Resources>

                <!-- Remove default highlight/selection background -->

                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>

                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{DynamicResource TextFillColorPrimary}"/>

                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>

                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource TextFillColorPrimary}"/>

            </Style.Resources>

            <Style.Triggers>

                <Trigger Property="IsSelected" Value="True">

                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>

                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>

                </Trigger>

            </Style.Triggers>

        </Style>



        <!-- Empty state for tabs with no data -->

        <Style x:Key="TabEmptyState" TargetType="TextBlock">

            <Setter Property="Text" Value="No data available"/>

            <Setter Property="FontSize" Value="14"/>

            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>

            <Setter Property="HorizontalAlignment" Value="Center"/>

            <Setter Property="VerticalAlignment" Value="Center"/>

            <Setter Property="Margin" Value="0,24,0,24"/>

        </Style>



        <!-- ─── Server Card summary row hover effect ─── -->

        <Style x:Key="SummaryRowBorder" TargetType="Border">

            <Setter Property="Padding" Value="14,12"/>

            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">

                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>

                </Trigger>

            </Style.Triggers>

        </Style>



        <!-- Sleek status dot style (used in server card status badge, NOT DataGrid) -->

        <Style x:Key="StatusDot" TargetType="Ellipse">

            <Setter Property="Width" Value="7"/>

            <Setter Property="Height" Value="7"/>

            <Setter Property="Fill" Value="White"/>

            <Setter Property="VerticalAlignment" Value="Center"/>

            <Setter Property="Margin" Value="0,0,7,0"/>

        </Style>



        <!-- Counts icon style -->

        <Style x:Key="CountIcon" TargetType="ui:SymbolIcon">

            <Setter Property="FontSize" Value="12"/>

            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>

            <Setter Property="VerticalAlignment" Value="Center"/>

        </Style>



        <!-- Count value style -->

        <Style x:Key="CountValue" TargetType="TextBlock">

            <Setter Property="FontSize" Value="12"/>

            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="VerticalAlignment" Value="Center"/>

        </Style>

    </Page.Resources>

    <Grid Margin="24,20,24,16">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->

        <!--  HEADER                                                      -->

        <!-- ═══════════════════════════════════════════════════════════ -->

        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>



            <StackPanel Grid.Column="0">

                <TextBlock Text="Server Monitoring" FontSize="28" FontWeight="Bold"/>

                <TextBlock Text="Monitor the status, printers, scanners, active clients, and print queues of all ShaPrint servers on the LAN in real-time."

                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"

                           FontSize="13" Margin="0,5,0,0" TextWrapping="Wrap"/>

            </StackPanel>



            <!-- Last Refreshed pill -->

            <Border Grid.Column="1" VerticalAlignment="Bottom"

                    Background="{DynamicResource ControlFillColorDefaultBrush}"

                    CornerRadius="20" Padding="14,7">

                <StackPanel Orientation="Horizontal">

                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="13" Margin="0,0,6,0"

                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">

                        <Run Text="Last refreshed: "/>

                        <Run Text="{Binding ViewModel.LastRefreshText, Mode=OneWay}" FontWeight="SemiBold"

                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                    </TextBlock>

                </StackPanel>

            </Border>

        </Grid>



        <!-- ═══════════════════════════════════════════════════════════ -->

        <!--  SUMMARY STAT CARDS                                         -->

        <!-- ═══════════════════════════════════════════════════════════ -->

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <ui:InfoBar IsOpen="True" Severity="Error" Title="Authentication Mismatch"
                        Message="{Binding ViewModel.AuthMismatchCount, StringFormat='\{0\} server(s) have a channel mismatch. Please check your Network Channel settings.'}"
                        Visibility="{Binding ViewModel.AuthMismatchCount, Converter={StaticResource IntToVis}}"
                        Margin="0,0,0,8"/>
            <ui:InfoBar IsOpen="True" Severity="Warning" Title="Weak Channel"
                        Message="Your Network Channel is weak or default. Others on the LAN can read monitor status."
                        Visibility="{Binding ViewModel.IsWeakChannel, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,8"/>
        </StackPanel>
        <UniformGrid Grid.Row="2" Columns="5" Rows="1" Margin="0,0,0,16">



            <!-- Total Servers -->

            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="All" ToolTip="View all servers">

                <ui:CardAction.Style>

                    <Style TargetType="ui:CardAction" BasedOn="{StaticResource StatCard}">

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding ViewModel.ActiveStatusFilter}" Value="All">

                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorAttentionBrush}"/>

                                <Setter Property="BorderThickness" Value="1"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </ui:CardAction.Style>

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Servers" 

                               FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.TotalServers}" 

                               FontSize="32" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>



                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="40" Height="40" CornerRadius="10" 

                            Background="{DynamicResource ControlFillColorDefaultBrush}" VerticalAlignment="Center">

                        <ui:SymbolIcon Symbol="Server24" FontSize="20" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    </Border>

                </Grid>

            </ui:CardAction>



            <!-- Online -->

            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Online" ToolTip="Filter by Online">

                <ui:CardAction.Style>

                    <Style TargetType="ui:CardAction" BasedOn="{StaticResource StatCard}">

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding ViewModel.ActiveStatusFilter}" Value="Online">

                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorSuccessBrush}"/>

                                <Setter Property="BorderThickness" Value="1"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </ui:CardAction.Style>

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Online" 

                               FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.OnlineCount}" 

                               FontSize="32" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>



                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="40" Height="40" CornerRadius="10" 

                            VerticalAlignment="Center">

                        <Border.Background><SolidColorBrush Color="#1A22C55E"/></Border.Background>

                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>

                    </Border>

                </Grid>

            </ui:CardAction>



            <!-- Warning -->

            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Warning" ToolTip="Filter by Warning">

                <ui:CardAction.Style>

                    <Style TargetType="ui:CardAction" BasedOn="{StaticResource StatCard}">

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding ViewModel.ActiveStatusFilter}" Value="Warning">

                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}"/>

                                <Setter Property="BorderThickness" Value="1"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </ui:CardAction.Style>

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Warning" 

                               FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.WarningCount}" 

                               FontSize="32" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>



                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="40" Height="40" CornerRadius="10" 

                            VerticalAlignment="Center">

                        <Border.Background><SolidColorBrush Color="#1AF59E0B"/></Border.Background>

                        <ui:SymbolIcon Symbol="Warning24" FontSize="20" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>

                    </Border>

                </Grid>

            </ui:CardAction>



            <!-- Unreachable -->
            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Unreachable" Margin="0,0,12,0" ToolTip="Filter by Unreachable">
                <ui:CardAction.Style>
                    <Style TargetType="ui:CardAction" BasedOn="{StaticResource StatCard}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.ActiveStatusFilter}" Value="Unreachable">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:CardAction.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Unreachable" 
                               FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.UnreachableCount}" 
                               FontSize="32" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="40" Height="40" CornerRadius="10" 
                            VerticalAlignment="Center">
                        <Border.Background><SolidColorBrush Color="#1AF59E0B"/></Border.Background>
                        <ui:SymbolIcon Symbol="WifiWarning24" FontSize="20" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                    </Border>
                </Grid>
            </ui:CardAction>

            <!-- Offline -->

            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Offline" Margin="0" ToolTip="Filter by Offline">

                <ui:CardAction.Style>

                    <Style TargetType="ui:CardAction" BasedOn="{StaticResource StatCard}">

                        <Setter Property="Margin" Value="0"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding ViewModel.ActiveStatusFilter}" Value="Offline">

                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>

                                <Setter Property="BorderThickness" Value="1"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </ui:CardAction.Style>

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Offline" 

                               FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.OfflineCount}" 

                               FontSize="32" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>



                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="40" Height="40" CornerRadius="10" 

                            VerticalAlignment="Center">

                        <Border.Background><SolidColorBrush Color="#1AEF4444"/></Border.Background>

                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="20" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                    </Border>

                </Grid>

            </ui:CardAction>

        </UniformGrid>



        <!-- ═══════════════════════════════════════════════════════════ -->

        <!--  SEARCH &amp; TOOLBAR                                       -->

        <!-- ═══════════════════════════════════════════════════════════ -->

        <Grid Grid.Row="3" Margin="0,0,0,16">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>



            <ui:TextBox Grid.Column="0"

                        Text="{Binding ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"

                        PlaceholderText="Filter servers by hostname or IP..."

                        Icon="{ui:SymbolIcon Search24}"

                        MaxWidth="400" HorizontalAlignment="Left" Width="400"

                        Margin="0,0,12,0"/>



            <ui:Button Grid.Column="1"

                       Command="{Binding ViewModel.ExpandAllCommand}"

                       Content="Expand All"

                       Icon="{ui:SymbolIcon ChevronDown24}"

                       Appearance="Secondary"

                       Margin="0,0,6,0"/>



            <ui:Button Grid.Column="2"

                       Command="{Binding ViewModel.CollapseAllCommand}"

                       Content="Collapse All"

                       Icon="{ui:SymbolIcon ChevronUp24}"

                       Appearance="Secondary"

                       Margin="0,0,10,0"/>



            <ui:Button Grid.Column="3"

                       Command="{Binding ViewModel.RefreshCommand}"

                       Content="Refresh"

                       Icon="{ui:SymbolIcon ArrowClockwise24}"

                       Appearance="Primary"/>

        </Grid>



        <!-- ═══════════════════════════════════════════════════════════ -->

        <!--  CONTENT AREA                                               -->

        <!-- ═══════════════════════════════════════════════════════════ -->

        <Grid Grid.Row="4">



            <!-- Loading State -->

            <StackPanel Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVis}}"

                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <ui:ProgressRing IsIndeterminate="True" Width="52" Height="52" Margin="0,0,0,20"/>

                <TextBlock Text="Discovering servers on the network..."

                           FontSize="15" FontWeight="Medium"

                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"

                           HorizontalAlignment="Center"/>

                <TextBlock Text="This may take a moment..."

                           FontSize="12"

                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"

                           HorizontalAlignment="Center" Margin="0,4,0,0"/>

            </StackPanel>



            <!-- Empty State -->

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel.Style>

                    <Style TargetType="StackPanel">

                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>

                            <MultiDataTrigger>

                                <MultiDataTrigger.Conditions>

                                    <Condition Binding="{Binding ViewModel.IsEmpty}" Value="True"/>

                                    <Condition Binding="{Binding ViewModel.IsLoading}" Value="False"/>

                                </MultiDataTrigger.Conditions>

                                <Setter Property="Visibility" Value="Visible"/>

                            </MultiDataTrigger>

                        </Style.Triggers>

                    </Style>

                </StackPanel.Style>

                <Border Width="80" Height="80" CornerRadius="40"

                        Background="{DynamicResource ControlFillColorDefaultBrush}"

                        HorizontalAlignment="Center" Margin="0,0,0,16">

                    <ui:SymbolIcon Symbol="Server24" FontSize="36"

                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"

                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                </Border>

                <TextBlock Text="No servers discovered" FontSize="18" FontWeight="SemiBold"

                           HorizontalAlignment="Center"/>

                <TextBlock Text="Make sure ShaPrint servers are running on the LAN."

                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"

                           HorizontalAlignment="Center" Margin="0,6,0,0"/>

                <ui:Button Content="Refresh Now"

                           Icon="{ui:SymbolIcon ArrowClockwise24}"

                           Command="{Binding ViewModel.RefreshCommand}"

                           Appearance="Primary"

                           HorizontalAlignment="Center"

                           Margin="0,16,0,0"/>

            </StackPanel>



            <!-- Filter No Results State -->

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel.Style>

                    <Style TargetType="StackPanel">

                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>

                            <MultiDataTrigger>

                                <MultiDataTrigger.Conditions>

                                    <Condition Binding="{Binding ViewModel.IsFilterNoResults}" Value="True"/>

                                    <Condition Binding="{Binding ViewModel.IsLoading}" Value="False"/>

                                </MultiDataTrigger.Conditions>

                                <Setter Property="Visibility" Value="Visible"/>

                            </MultiDataTrigger>

                        </Style.Triggers>

                    </Style>

                </StackPanel.Style>

                <Border Width="80" Height="80" CornerRadius="40"

                        Background="{DynamicResource ControlFillColorDefaultBrush}"

                        HorizontalAlignment="Center" Margin="0,0,0,16">

                    <ui:SymbolIcon Symbol="Search24" FontSize="36"

                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"

                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                </Border>

                <TextBlock Text="No servers match your filter"

                           FontSize="18" FontWeight="SemiBold"

                           HorizontalAlignment="Center"/>

                <TextBlock Text="Try adjusting your search criteria."

                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"

                           HorizontalAlignment="Center" Margin="0,6,0,0"/>

            </StackPanel>



            <!-- ─────────────────────────────────────────────────── -->

            <!--  Servers List                                        -->

            <!-- ─────────────────────────────────────────────────── -->

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <ScrollViewer.Style>

                    <Style TargetType="ScrollViewer">

                        <Setter Property="Visibility" Value="Visible"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding ViewModel.IsEmpty}" Value="True">

                                <Setter Property="Visibility" Value="Collapsed"/>

                            </DataTrigger>

                            <DataTrigger Binding="{Binding ViewModel.IsLoading}" Value="True">

                                <Setter Property="Visibility" Value="Collapsed"/>

                            </DataTrigger>

                            <DataTrigger Binding="{Binding ViewModel.IsFilterNoResults}" Value="True">

                                <Setter Property="Visibility" Value="Collapsed"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </ScrollViewer.Style>



                <ItemsControl ItemsSource="{Binding ViewModel.FilteredServers}">

                    <ItemsControl.ItemContainerStyle>

                        <Style TargetType="ContentPresenter">

                            <Setter Property="Margin" Value="0,0,0,16"/>

                        </Style>

                    </ItemsControl.ItemContainerStyle>



                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <!-- Server Card -->

                            <ui:Card Padding="0" VerticalAlignment="Top"

                                     BorderThickness="1"

                                     BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">

                                <Grid>

                                    <Grid.RowDefinitions>

                                        <RowDefinition Height="Auto"/>

                                        <RowDefinition Height="Auto"/>

                                    </Grid.RowDefinitions>



                                    <!-- ─────────────────────── -->

                                    <!--  SUMMARY ROW (compact)    -->

                                    <!-- ─────────────────────── -->

                                    <Border Grid.Row="0" Padding="14,12"

                                            Style="{StaticResource SummaryRowBorder}">

                                        <Border.InputBindings>

                                            <MouseBinding MouseAction="LeftClick"

                                                          Command="{Binding DataContext.ViewModel.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=Page}}"

                                                          CommandParameter="{Binding}"/>

                                        </Border.InputBindings>

                                        <Grid>

                                            <Grid.ColumnDefinitions>

                                                <ColumnDefinition Width="Auto"/>

                                                <ColumnDefinition Width="3*"/>

                                                <ColumnDefinition Width="1.8*"/>

                                                <ColumnDefinition Width="1.5*"/>

                                                <ColumnDefinition Width="Auto"/>

                                            </Grid.ColumnDefinitions>



                                            <!-- Status Badge -->

                                            <Border Grid.Column="0"

                                                    Background="{Binding StatusBackgroundBrush}"

                                                    BorderBrush="{Binding StatusBorderBrush}"

                                                    BorderThickness="1"

                                                    CornerRadius="6" Padding="8,3.5"

                                                    Margin="0,0,18,0" VerticalAlignment="Center">

                                                <StackPanel Orientation="Horizontal">

                                                    <Ellipse Width="6" Height="6"

                                                             Fill="{Binding StatusTextBrush}"

                                                             VerticalAlignment="Center"

                                                             Margin="0,0,6,0"/>

                                                    <TextBlock Text="{Binding Status, Mode=OneWay}"

                                                               Foreground="{Binding StatusTextBrush}"

                                                               FontWeight="SemiBold" FontSize="11"/>

                                                </StackPanel>

                                            </Border>



                                            <!-- Hostname &amp; IP &amp; Version -->

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">

                                                    <TextBlock Text="{Binding HostName, Mode=OneWay}"

                                                               FontSize="14" FontWeight="SemiBold"

                                                               TextTrimming="CharacterEllipsis" MaxWidth="220"

                                                               ToolTip="{Binding HostName, Mode=OneWay}"/>

                                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                            CornerRadius="4" Padding="5,2" Margin="8,0,0,0"

                                                            VerticalAlignment="Center"

                                                            BorderThickness="1"

                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">

                                                        <TextBlock Text="{Binding Version, Mode=OneWay, StringFormat='v{0}'}"

                                                                   FontSize="10.5"

                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                                    </Border>

                                                </StackPanel>

                                                <TextBlock Text="{Binding IpAddress, Mode=OneWay}" FontSize="11.5"

                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"

                                                           TextTrimming="CharacterEllipsis"

                                                           ToolTip="{Binding IpAddress, Mode=OneWay}"/>

                                            </StackPanel>



                                            <!-- Counts + Channel -->

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"

                                                        CornerRadius="4" Padding="5,1.5"

                                                        HorizontalAlignment="Left" Margin="0,0,0,6"

                                                        ToolTip="Network Channel">

                                                    <TextBlock FontSize="10.5"

                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">

                                                         <Run Text="CH " FontWeight="SemiBold"/>

                                                         <Run Text="{Binding NetworkChannel, Mode=OneWay}"/>

                                                    </TextBlock>

                                                </Border>

                                                <StackPanel Orientation="Horizontal" ToolTip="Printers, Scanners, Active Clients">

                                                     <!-- Printers Badge -->

                                                     <Border Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                             BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                             BorderThickness="1"

                                                             CornerRadius="4"

                                                             Padding="6,2"

                                                             Margin="0,0,6,0">

                                                         <StackPanel Orientation="Horizontal">

                                                             <ui:SymbolIcon Symbol="Print24" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0"/>

                                                             <TextBlock Text="{Binding Payload.Printers.Count, Mode=OneWay, FallbackValue=0}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                         </StackPanel>

                                                     </Border>

                                                     <!-- Scanners Badge -->

                                                     <Border Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                             BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                             BorderThickness="1"

                                                             CornerRadius="4"

                                                             Padding="6,2"

                                                             Margin="0,0,6,0">

                                                         <StackPanel Orientation="Horizontal">

                                                             <ui:SymbolIcon Symbol="Scan24" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0"/>

                                                             <TextBlock Text="{Binding Payload.Scanners.Count, Mode=OneWay, FallbackValue=0}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                         </StackPanel>

                                                     </Border>

                                                     <!-- Connected Clients Badge -->

                                                     <Border Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                             BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                             BorderThickness="1"

                                                             CornerRadius="4"

                                                             Padding="6,2">

                                                         <StackPanel Orientation="Horizontal">

                                                             <ui:SymbolIcon Symbol="People24" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0"/>

                                                             <TextBlock Text="{Binding Payload.ActiveClients.Count, Mode=OneWay, FallbackValue=0}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                         </StackPanel>

                                                     </Border>

                                                </StackPanel>

                                            </StackPanel>



                                            <!-- Uptime &amp; Last Seen -->

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">

                                                    <ui:SymbolIcon Symbol="Clock24" FontSize="12"

                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"

                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>

                                                    <TextBlock FontSize="11.5" VerticalAlignment="Center">

                                                        <Run Text="Uptime: "

                                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                                        <Run Text="{Binding UptimeText, Mode=OneWay}" FontWeight="SemiBold"

                                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                    </TextBlock>

                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal">

                                                    <ui:SymbolIcon Symbol="Eye24" FontSize="12"

                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"

                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>

                                                    <TextBlock FontSize="11.5" VerticalAlignment="Center">

                                                        <Run Text="Seen: "

                                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                                        <Run Text="{Binding LastSeenText, Mode=OneWay}" FontWeight="SemiBold"

                                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                    </TextBlock>

                                                </StackPanel>

                                            </StackPanel>
                                             <!-- Expand / Collapse Chevron Indicator -->

                                             <ui:SymbolIcon Grid.Column="4"

                                                            VerticalAlignment="Center"

                                                            FontSize="16"

                                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"

                                                            Margin="12,0,4,0">

                                                 <ui:SymbolIcon.Style>

                                                     <Style TargetType="ui:SymbolIcon">

                                                         <Setter Property="Symbol" Value="ChevronDown24"/>

                                                         <Style.Triggers>

                                                             <DataTrigger Binding="{Binding IsExpanded}" Value="True">

                                                                 <Setter Property="Symbol" Value="ChevronUp24"/>

                                                             </DataTrigger>

                                                         </Style.Triggers>

                                                     </Style>

                                                 </ui:SymbolIcon.Style>

                                             </ui:SymbolIcon>

                                        </Grid>

                                    </Border>



                                    <!-- ─────────────────────── -->

                                    <!--  EXPANDED DETAIL PANEL  -->

                                    <!-- ─────────────────────── -->

                                    <Grid Grid.Row="1"

                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">

                                        <Grid.RowDefinitions>

                                            <RowDefinition Height="Auto"/>

                                            <RowDefinition Height="Auto"/>

                                            <RowDefinition Height="*"/>

                                        </Grid.RowDefinitions>



                                        <!-- Divider line -->

                                        <Border Grid.Row="0" Height="1"

                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>



                                        <!-- Error Banner -->

                                        <Border Grid.Row="1"

                                                Margin="18,12,18,0"

                                                CornerRadius="8"

                                                BorderThickness="1"

                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}, FallbackValue=Collapsed}">

                                            <Grid>

                                                <Grid.ColumnDefinitions>

                                                    <ColumnDefinition Width="4"/>

                                                    <ColumnDefinition Width="*"/>

                                                </Grid.ColumnDefinitions>

                                                <!-- Left accent bar -->

                                                <Rectangle Grid.Column="0" Fill="{DynamicResource SystemFillColorCriticalBrush}" RadiusX="4" RadiusY="4"/>

                                                <!-- Content area -->

                                                <Border Grid.Column="1" Padding="14,10"

                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                        CornerRadius="0,8,8,0">

                                                    <StackPanel Orientation="Horizontal">

                                                        <Border CornerRadius="6" Padding="6,4"

                                                                Background="#1AEF4444"

                                                                VerticalAlignment="Center" Margin="0,0,10,0">

                                                            <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="14"

                                                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                                                        </Border>

                                                        <TextBlock VerticalAlignment="Center" FontSize="13">

                                                            <Run Text="Recent errors detected — check the "

                                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                            <Run Text="Errors" FontWeight="Bold"

                                                                 Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                                                            <Run Text=" tab below."

                                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                        </TextBlock>

                                                    </StackPanel>

                                                </Border>

                                            </Grid>

                                        </Border>



                                        <!-- Detail Tabs -->

                                        <TabControl Grid.Row="2" Margin="18,8,18,16" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">



                                            <!-- Printers Tab -->

                                            <TabItem>

                                                <TabItem.Header>

                                                     <StackPanel Orientation="Horizontal">

                                                         <ui:SymbolIcon Symbol="Print24" FontSize="13" Margin="0,0,6,0"/>

                                                         <TextBlock Text="Printers"/>

                                                         <Border CornerRadius="10" Padding="6,1.5" Margin="6,0,0,0"

                                                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"

                                                                 BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                                 BorderThickness="1"

                                                                 Visibility="{Binding Payload.Printers.Count, Converter={StaticResource IntToVis}}">

                                                             <TextBlock Text="{Binding Payload.Printers.Count, Mode=OneWay}"

                                                                        FontSize="10.5" FontWeight="Bold"

                                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>

                                                         </Border>

                                                     </StackPanel>

                                                 </TabItem.Header>

                                                <Border Style="{StaticResource TabContentPanel}">

                                                    <Grid>

                                                        <TextBlock Text="No printers registered" Style="{StaticResource TabEmptyState}"

                                                                   Visibility="{Binding Payload.Printers.Count, Converter={StaticResource IntToVis}, ConverterParameter=Inverse}"/>

                                                        <ui:DataGrid Style="{StaticResource TabDataGrid}"

                                                                  CellStyle="{StaticResource ShadcnCellStyle}"

                                                                  ItemsSource="{Binding Payload.Printers}"

                                                                  Visibility="{Binding Payload.Printers.Count, Converter={StaticResource IntToVis}}">

                                                            <DataGrid.Columns>

                                                                <DataGridTextColumn Header="Printer Name"

                                                                                    Binding="{Binding Name}" Width="4*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTemplateColumn Header="Status" Width="1.5*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                                                                                <Ellipse Width="7" Height="7"

                                                                                         Fill="{Binding Status, Converter={StaticResource StatusToDotBrush}}"

                                                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>

                                                                                <TextBlock Text="{Binding Status}" FontSize="11.5"

                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                                            </StackPanel>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                                <DataGridTemplateColumn Header="Queue" Width="1.2*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                                                                                <Border CornerRadius="4" Padding="6,2"

                                                                                        Background="{DynamicResource ControlFillColorDefaultBrush}">

                                                                                    <TextBlock FontSize="12" FontWeight="SemiBold"

                                                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">

                                                                                        <Run Text="{Binding QueueLength}"/>

                                                                                        <Run Text=" jobs" FontWeight="Normal" FontSize="11"

                                                                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                                                                    </TextBlock>

                                                                                </Border>

                                                                            </StackPanel>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                                <DataGridTextColumn Header="Error Description"

                                                                                    Binding="{Binding ErrorDescription}" Width="4*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                            </DataGrid.Columns>

                                                        </ui:DataGrid>

                                                    </Grid>

                                                </Border>

                                            </TabItem>



                                            <!-- Scanners Tab -->

                                            <TabItem>

                                                <TabItem.Header>

                                                    <StackPanel Orientation="Horizontal">

                                                        <ui:SymbolIcon Symbol="Scan24" FontSize="13" Margin="0,0,6,0"/>

                                                        <TextBlock Text="Scanners"/>

                                                        <Border CornerRadius="10" Padding="6,1.5" Margin="6,0,0,0"

                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"

                                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                                BorderThickness="1"

                                                                Visibility="{Binding Payload.Scanners.Count, Converter={StaticResource IntToVis}}">

                                                            <TextBlock Text="{Binding Payload.Scanners.Count, Mode=OneWay}"

                                                                       FontSize="10.5" FontWeight="Bold"

                                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>

                                                        </Border>

                                                    </StackPanel>

                                                </TabItem.Header>

                                                <Border Style="{StaticResource TabContentPanel}">

                                                    <Grid>

                                                        <TextBlock Text="No scanners registered" Style="{StaticResource TabEmptyState}"

                                                                   Visibility="{Binding Payload.Scanners.Count, Converter={StaticResource IntToVis}, ConverterParameter=Inverse}"/>

                                                        <ui:DataGrid Style="{StaticResource TabDataGrid}"

                                                                  CellStyle="{StaticResource ShadcnCellStyle}"

                                                                  ItemsSource="{Binding Payload.Scanners}"

                                                                  Visibility="{Binding Payload.Scanners.Count, Converter={StaticResource IntToVis}}">

                                                            <DataGrid.Columns>

                                                                <DataGridTextColumn Header="Scanner Name"

                                                                                    Binding="{Binding Name}" Width="4*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTemplateColumn Header="Status" Width="1.5*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                                                                                <Ellipse Width="7" Height="7"

                                                                                         Fill="{Binding Status, Converter={StaticResource StatusToDotBrush}}"

                                                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>

                                                                                <TextBlock Text="{Binding Status}" FontSize="11.5"

                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                                            </StackPanel>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                                <DataGridTextColumn Header="Last Active"

                                                                                    Binding="{Binding LastScanAgo, FallbackValue='N/A'}"

                                                                                    Width="2.5*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                            </DataGrid.Columns>

                                                        </ui:DataGrid>

                                                    </Grid>

                                                </Border>

                                            </TabItem>



                                            <!-- Connected Clients Tab -->

                                            <TabItem>

                                                <TabItem.Header>

                                                     <StackPanel Orientation="Horizontal">

                                                         <ui:SymbolIcon Symbol="People24" FontSize="13" Margin="0,0,6,0"/>

                                                         <TextBlock Text="Connected Clients"/>

                                                         <Border CornerRadius="10" Padding="6,1.5" Margin="6,0,0,0"

                                                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"

                                                                 BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                                 BorderThickness="1"

                                                                 Visibility="{Binding Payload.ActiveClients.Count, Converter={StaticResource IntToVis}}">

                                                             <TextBlock Text="{Binding Payload.ActiveClients.Count, Mode=OneWay}"

                                                                        FontSize="10.5" FontWeight="Bold"

                                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>

                                                         </Border>

                                                     </StackPanel>

                                                 </TabItem.Header>

                                                <Border Style="{StaticResource TabContentPanel}">

                                                    <Grid>

                                                        <TextBlock Text="No connected clients" Style="{StaticResource TabEmptyState}"

                                                                   Visibility="{Binding Payload.ActiveClients.Count, Converter={StaticResource IntToVis}, ConverterParameter=Inverse}"/>

                                                        <ui:DataGrid Style="{StaticResource TabDataGrid}"

                                                                  CellStyle="{StaticResource ShadcnCellStyle}"

                                                                  ItemsSource="{Binding Payload.ActiveClients}"

                                                                  Visibility="{Binding Payload.ActiveClients.Count, Converter={StaticResource IntToVis}}">

                                                            <DataGrid.Columns>

                                                                <DataGridTextColumn Header="Client IP"

                                                                                    Binding="{Binding Ip}" Width="1*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTextColumn Header="Connected Since"

                                                                                    Binding="{Binding ConnectedSince, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"

                                                                                    Width="1*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                            </DataGrid.Columns>

                                                        </ui:DataGrid>

                                                    </Grid>

                                                </Border>

                                            </TabItem>



                                            <!-- Job Activity Tab -->

                                            <TabItem>

                                                <TabItem.Header>

                                                     <StackPanel Orientation="Horizontal">

                                                         <ui:SymbolIcon Symbol="ClipboardTaskListLtr24" FontSize="13" Margin="0,0,6,0"/>

                                                         <TextBlock Text="Job Activity"/>

                                                         <Border CornerRadius="10" Padding="6,1.5" Margin="6,0,0,0"

                                                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"

                                                                 BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"

                                                                 BorderThickness="1"

                                                                 Visibility="{Binding Payload.RecentJobs.Count, Converter={StaticResource IntToVis}}">

                                                             <TextBlock Text="{Binding Payload.RecentJobs.Count, Mode=OneWay}"

                                                                        FontSize="10.5" FontWeight="Bold"

                                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>

                                                         </Border>

                                                     </StackPanel>

                                                 </TabItem.Header>

                                                <Border Style="{StaticResource TabContentPanel}">

                                                    <Grid>

                                                        <TextBlock Text="No recent job activity" Style="{StaticResource TabEmptyState}"

                                                                   Visibility="{Binding Payload.RecentJobs.Count, Converter={StaticResource IntToVis}, ConverterParameter=Inverse}"/>

                                                        <ui:DataGrid Style="{StaticResource TabDataGrid}"

                                                                  CellStyle="{StaticResource ShadcnCellStyle}"

                                                                  ItemsSource="{Binding Payload.RecentJobs}"

                                                                  Visibility="{Binding Payload.RecentJobs.Count, Converter={StaticResource IntToVis}}">

                                                            <DataGrid.Columns>

                                                                <DataGridTextColumn Header="Time"

                                                                                    Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"

                                                                                    Width="1.8*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTemplateColumn Header="Type" Width="0.8*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                                                                <!-- Print job icon -->

                                                                <ui:SymbolIcon Symbol="Print24" FontSize="13" Margin="0,0,5,0"

                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">

                                                                    <ui:SymbolIcon.Style>

                                                                        <Style TargetType="ui:SymbolIcon">

                                                                            <Setter Property="Visibility" Value="Collapsed"/>

                                                                            <Style.Triggers>

                                                                                <DataTrigger Binding="{Binding Type}" Value="print">

                                                                                    <Setter Property="Visibility" Value="Visible"/>

                                                                                </DataTrigger>

                                                                            </Style.Triggers>

                                                                        </Style>

                                                                    </ui:SymbolIcon.Style>

                                                                </ui:SymbolIcon>

                                                                                <!-- Scan job icon -->

                                                                                <ui:SymbolIcon Symbol="Scan24" FontSize="13" Margin="0,0,5,0"

                                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">

                                                                                    <ui:SymbolIcon.Style>

                                                                                        <Style TargetType="ui:SymbolIcon">

                                                                                            <Setter Property="Visibility" Value="Collapsed"/>

                                                                                            <Style.Triggers>

                                                                                                <DataTrigger Binding="{Binding Type}" Value="scan">

                                                                                                    <Setter Property="Visibility" Value="Visible"/>

                                                                                                </DataTrigger>

                                                                                            </Style.Triggers>

                                                                                        </Style>

                                                                                    </ui:SymbolIcon.Style>

                                                                                </ui:SymbolIcon>

                                                                                <TextBlock Text="{Binding Type}" FontSize="12"

                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                                            </StackPanel>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                                <DataGridTextColumn Header="Device"

                                                                                    Binding="{Binding PrinterName}" Width="2*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTextColumn Header="Job Title"

                                                                                    Binding="{Binding Document}" Width="3*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTextColumn Header="Client IP"

                                                                                    Binding="{Binding ClientIp}" Width="1.5*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTemplateColumn Header="Status" Width="1.5*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                                                                                <Ellipse Width="7" Height="7"

                                                                                         Fill="{Binding Status, Converter={StaticResource StatusToDotBrush}}"

                                                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>

                                                                                <TextBlock Text="{Binding Status}" FontSize="11.5"

                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                                            </StackPanel>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                            </DataGrid.Columns>

                                                        </ui:DataGrid>

                                                    </Grid>

                                                </Border>

                                            </TabItem>



                                            <!-- Errors Tab -->

                                            <TabItem>

                                                <TabItem.Header>

                                                    <StackPanel Orientation="Horizontal">

                                                        <ui:SymbolIcon Symbol="Warning24" FontSize="13" Margin="0,0,6,0"

                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                                                        <TextBlock Text="Errors"

                                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                                                        <Border CornerRadius="10" Padding="6,1.5" Margin="6,0,0,0"

                                                                 Background="#1AEF4444"

                                                                 BorderBrush="#33EF4444"

                                                                 BorderThickness="1"

                                                                 Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}}">

                                                            <TextBlock Text="{Binding Payload.Errors.Count, Mode=OneWay}"

                                                                       FontSize="10.5" FontWeight="Bold"

                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                                                        </Border>

                                                    </StackPanel>

                                                </TabItem.Header>

                                                <Border Style="{StaticResource TabContentPanel}">

                                                    <Grid>

                                                        <TextBlock Text="No errors recorded" Style="{StaticResource TabEmptyState}"

                                                                   Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}, ConverterParameter=Inverse}"/>

                                                        <ui:DataGrid Style="{StaticResource TabDataGrid}"

                                                                  CellStyle="{StaticResource ShadcnCellStyle}"

                                                                  ItemsSource="{Binding Payload.Errors}"

                                                                  Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}}">

                                                            <DataGrid.Columns>

                                                                <DataGridTextColumn Header="Time"

                                                                                    Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"

                                                                                    Width="1.8*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTextColumn Header="Source"

                                                                                    Binding="{Binding Source}" Width="1.5*"

                                                                                    ElementStyle="{StaticResource CellTextStyle}"/>

                                                                <DataGridTemplateColumn Header="Error Message" Width="5*">

                                                                    <DataGridTemplateColumn.CellTemplate>

                                                                        <DataTemplate>

                                                                            <Border CornerRadius="4" Padding="8,3"

                                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"

                                                                                    HorizontalAlignment="Left" Margin="0,2">

                                                                                <TextBlock Text="{Binding Message}"

                                                                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"

                                                                                           FontSize="12" TextWrapping="Wrap"

                                                                                           VerticalAlignment="Center"

                                                                                           MaxWidth="400"/>

                                                                            </Border>

                                                                        </DataTemplate>

                                                                    </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>

                                                            </DataGrid.Columns>

                                                        </ui:DataGrid>

                                                    </Grid>

                                                </Border>

                                            </TabItem>



                                        </TabControl>

                                    </Grid>

                                </Grid>

                            </ui:Card>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Grid>

    </Grid>

</Page>

