<Page x:Class="ShaPrint.WpfApp.Views.Pages.MonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:ShaPrint.WpfApp.Converters"
      Title="Server Monitoring">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:IntToVisibilityConverter x:Key="IntToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        
        <!-- TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,12,0,0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Summary Stats -->
            <RowDefinition Height="Auto"/> <!-- Filter / Refresh bar -->
            <RowDefinition Height="*"/>    <!-- Content Area (Grid/List + Empty states) -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Server Monitoring Panel" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Monitor the status, printers, scanners, active clients, and print queues of all ShaPrint servers on the LAN in real-time." 
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal">
                <TextBlock Text="Last refreshed: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                <TextBlock Text="{Binding ViewModel.LastRefreshText}" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- Summary Stats -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <ui:Card Grid.Column="0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Total Servers" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:SymbolIcon Symbol="Server24" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ViewModel.TotalServers}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Online -->
            <ui:Card Grid.Column="2" Padding="12">
                <StackPanel>
                    <TextBlock Text="Online" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="{Binding ViewModel.OnlineCount}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Warning -->
            <ui:Card Grid.Column="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="Warning" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                        <TextBlock Text="{Binding ViewModel.WarningCount}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Offline -->
            <ui:Card Grid.Column="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Offline" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="{Binding ViewModel.OfflineCount}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Search & Refresh bar -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search box -->
            <ui:TextBox Grid.Column="0" 
                        Text="{Binding ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Filter servers by hostname or IP..."
                        Icon="{ui:SymbolIcon Search24}"
                        Margin="0,0,12,0"/>

            <!-- Expand All -->
            <ui:Button Grid.Column="1" 
                       Command="{Binding ViewModel.ExpandAllCommand}"
                       Content="Expand All"
                       Icon="{ui:SymbolIcon ChevronDown24}"
                       Appearance="Transparent"
                       Margin="0,0,4,0"/>

            <!-- Collapse All -->
            <ui:Button Grid.Column="2" 
                       Command="{Binding ViewModel.CollapseAllCommand}"
                       Content="Collapse All"
                       Icon="{ui:SymbolIcon ChevronUp24}"
                       Appearance="Transparent"
                       Margin="0,0,12,0"/>

            <!-- Refresh button -->
            <ui:Button Grid.Column="3" 
                       Command="{Binding ViewModel.RefreshCommand}"
                       Content="Refresh"
                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Appearance="Primary"/>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="3">
            
            <!-- Loading State -->
            <StackPanel Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVis}}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,16"/>
                <TextBlock Text="Discovering servers on the network..." FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            
            <!-- Empty State (No Servers) -->
            <StackPanel Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource BoolToVis}}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="Server24" FontSize="48" Foreground="{DynamicResource TextFillColorDisabledBrush}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                <TextBlock Text="No servers discovered" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Make sure ShaPrint servers are running on the LAN." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Filter No Results State -->
            <StackPanel Visibility="{Binding ViewModel.IsFilterNoResults, Converter={StaticResource BoolToVis}}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Search24" FontSize="48" Foreground="{DynamicResource TextFillColorDisabledBrush}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                <TextBlock Text="No servers match your filter" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Try adjusting your search criteria." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Servers List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ViewModel.IsFilterNoResults}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <ListBox ItemsSource="{Binding ViewModel.FilteredServers}" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Padding="16" Margin="0" VerticalAlignment="Top">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Collapsed Row (Summary) -->
                                        <RowDefinition Height="Auto"/> <!-- Expanded Row (Details) -->
                                    </Grid.RowDefinitions>

                                    <!-- Summary Row -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Status Badge -->
                                            <ColumnDefinition Width="2.5*"/> <!-- Hostname, IP, Version -->
                                            <ColumnDefinition Width="2.5*"/> <!-- Counts / Channel -->
                                            <ColumnDefinition Width="1.5*"/> <!-- Uptime / Seen -->
                                            <ColumnDefinition Width="Auto"/> <!-- Expand/Collapse button -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Status Badge -->
                                        <Border Grid.Column="0" Background="{Binding StatusBrush}" 
                                                CornerRadius="12" Padding="12,4" Margin="0,0,16,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>

                                        <!-- Hostname & IP & Version -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding HostName}" FontSize="16" FontWeight="SemiBold"/>
                                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="4,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding IpAddress}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Counts & Network Channel -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="4,2" Margin="0,0,8,0">
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                        <Run Text="CH: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding NetworkChannel, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Print24" Margin="0,0,4,0" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Payload.Printers.Count, FallbackValue=0}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                                
                                                <ui:SymbolIcon Symbol="Scan24" Margin="0,0,4,0" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Payload.Scanners.Count, FallbackValue=0}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                                
                                                <ui:SymbolIcon Symbol="People24" Margin="0,0,4,0" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Payload.ActiveClients.Count, FallbackValue=0}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Uptime & Last Seen -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <ui:SymbolIcon Symbol="Clock24" FontSize="14" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock FontSize="12">
                                                    <Run Text="Uptime: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Run Text="{Binding UptimeText, Mode=OneWay}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Eye24" FontSize="14" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock FontSize="12">
                                                    <Run Text="Seen: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Run Text="{Binding LastSeenText, Mode=OneWay}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Expand / Collapse Toggle button -->
                                        <ui:Button Grid.Column="4" 
                                                   Command="{Binding DataContext.ViewModel.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   Appearance="Transparent"
                                                   VerticalAlignment="Center">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Icon" Value="{ui:SymbolIcon ChevronDown24}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Icon" Value="{ui:SymbolIcon ChevronUp24}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                    </Grid>

                                    <!-- Details Row (Visible when IsExpanded = True) -->
                                    <Grid Grid.Row="1" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" Margin="0,16,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Error Banner -->
                                            <RowDefinition Height="*"/>    <!-- Detail Tabs -->
                                        </Grid.RowDefinitions>

                                        <!-- Error Banner -->
                                        <Border Grid.Row="0" Background="{DynamicResource SystemFillColorCriticalBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                                Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}, FallbackValue=Collapsed}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Warning24" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Recent errors detected on this server! Check the Errors tab below." Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Detail Tabs -->
                                        <TabControl Grid.Row="1">
                                            <!-- Printers Tab -->
                                            <TabItem Header="Printers">
                                                <ListView ItemsSource="{Binding Payload.Printers}" MaxHeight="300" MinHeight="100">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Printer Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
                                                            <GridViewColumn Header="Status" Width="100">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Queue" Width="80">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                                                            <TextBlock Text="{Binding QueueLength}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Issues / Notes" DisplayMemberBinding="{Binding ErrorDescription}" Width="300"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>

                                            <!-- Scanners Tab -->
                                            <TabItem Header="Scanners">
                                                <ListView ItemsSource="{Binding Payload.Scanners}" MaxHeight="300" MinHeight="100">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Scanner Name" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                                            <GridViewColumn Header="Status" Width="120">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Last Active" DisplayMemberBinding="{Binding LastScanAgo, FallbackValue='N/A'}" Width="150"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>

                                            <!-- Connected Clients Tab -->
                                            <TabItem Header="Connected Clients">
                                                <ListView ItemsSource="{Binding Payload.ActiveClients}" MaxHeight="300" MinHeight="100">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Client IP Address" DisplayMemberBinding="{Binding Ip}" Width="250"/>
                                                            <GridViewColumn Header="Connected Since" DisplayMemberBinding="{Binding ConnectedSince, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="250"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>

                                            <!-- Print/Scan Jobs History Tab -->
                                            <TabItem Header="Job Activity">
                                                <ListView ItemsSource="{Binding Payload.RecentJobs}" MaxHeight="300" MinHeight="100">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="80"/>
                                                            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="80"/>
                                                            <GridViewColumn Header="Device" DisplayMemberBinding="{Binding PrinterName}" Width="200"/>
                                                            <GridViewColumn Header="Job Title" DisplayMemberBinding="{Binding Document}" Width="250"/>
                                                            <GridViewColumn Header="Client IP" DisplayMemberBinding="{Binding ClientIp}" Width="120"/>
                                                            <GridViewColumn Header="Status" Width="100">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>

                                            <!-- Errors Tab -->
                                            <TabItem Header="Errors">
                                                <ListView ItemsSource="{Binding Payload.Errors}" MaxHeight="300" MinHeight="100">
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="100"/>
                                                            <GridViewColumn Header="Source" DisplayMemberBinding="{Binding Source}" Width="150"/>
                                                            <GridViewColumn Header="Error Message" DisplayMemberBinding="{Binding Message}" Width="500"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                            </TabItem>
                                        </TabControl>
                                    </Grid>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
