<Page x:Class="ShaPrint.WpfApp.Views.Pages.MonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:ShaPrint.WpfApp.Converters"
      Title="Server Monitoring">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:IntToVisibilityConverter x:Key="IntToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Stat Card padding style -->
        <Style x:Key="StatCard" TargetType="ui:CardAction" BasedOn="{StaticResource {x:Type ui:CardAction}}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="IsChevronVisible" Value="False"/>
        </Style>

        <!-- Tab Control -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8,0,0"/>
        </Style>

        <!-- Tab Item with custom pill template -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Margin="0,0,4,0"
                                Background="Transparent" CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status pill style for DataGrid cells -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
        </Style>

        <!-- Tab content panel — wraps each DataGrid -->
        <Style x:Key="TabContentPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="0,0,8,8"/>
            <Setter Property="MaxHeight" Value="300"/>
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  HEADER                                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Server Monitoring" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Monitor the status, printers, scanners, active clients, and print queues of all ShaPrint servers on the LAN in real-time."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Last Refreshed pill -->
            <Border Grid.Column="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="20" Padding="14,7">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="13" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Last refreshed: "/>
                        <Run Text="{Binding ViewModel.LastRefreshText, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  SUMMARY STAT CARDS                                         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,0,0,16">

            <!-- Total Servers -->
            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="All" Style="{StaticResource StatCard}" ToolTip="View all servers">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Servers" 
                               FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.TotalServers}" 
                               FontSize="36" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="48" Height="48" CornerRadius="12" 
                            Background="{DynamicResource ControlFillColorDefaultBrush}" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Server24" FontSize="24" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>
                </Grid>
            </ui:CardAction>

            <!-- Online -->
            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Online" Style="{StaticResource StatCard}" ToolTip="Filter by Online">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Online" 
                               FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.OnlineCount}" 
                               FontSize="36" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="48" Height="48" CornerRadius="12" 
                            VerticalAlignment="Center">
                        <Border.Background><SolidColorBrush Color="#1A22C55E"/></Border.Background>
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="24" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                    </Border>
                </Grid>
            </ui:CardAction>

            <!-- Warning -->
            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Warning" Style="{StaticResource StatCard}" ToolTip="Filter by Warning">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Warning" 
                               FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.WarningCount}" 
                               FontSize="36" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="48" Height="48" CornerRadius="12" 
                            VerticalAlignment="Center">
                        <Border.Background><SolidColorBrush Color="#1AF59E0B"/></Border.Background>
                        <ui:SymbolIcon Symbol="Warning24" FontSize="24" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                    </Border>
                </Grid>
            </ui:CardAction>

            <!-- Offline -->
            <ui:CardAction Command="{Binding ViewModel.SetStatusFilterCommand}" CommandParameter="Offline" Style="{StaticResource StatCard}" Margin="0" ToolTip="Filter by Offline">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Offline" 
                               FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ViewModel.OfflineCount}" 
                               FontSize="36" FontWeight="Bold" Margin="0,4,0,0" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>

                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="48" Height="48" CornerRadius="12" 
                            VerticalAlignment="Center">
                        <Border.Background><SolidColorBrush Color="#1AEF4444"/></Border.Background>
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="24" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                    </Border>
                </Grid>
            </ui:CardAction>
        </UniformGrid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  SEARCH &amp; TOOLBAR                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                        Text="{Binding ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Filter servers by hostname or IP..."
                        Icon="{ui:SymbolIcon Search24}"
                        MaxWidth="400" HorizontalAlignment="Left" Width="400"
                        Margin="0,0,12,0"/>

            <ui:Button Grid.Column="1"
                       Command="{Binding ViewModel.ExpandAllCommand}"
                       Content="Expand All"
                       Icon="{ui:SymbolIcon ChevronDown24}"
                       Appearance="Secondary"
                       Margin="0,0,6,0"/>

            <ui:Button Grid.Column="2"
                       Command="{Binding ViewModel.CollapseAllCommand}"
                       Content="Collapse All"
                       Icon="{ui:SymbolIcon ChevronUp24}"
                       Appearance="Secondary"
                       Margin="0,0,10,0"/>

            <ui:Button Grid.Column="3"
                       Command="{Binding ViewModel.RefreshCommand}"
                       Content="Refresh"
                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Appearance="Primary"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  CONTENT AREA                                               -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">

            <!-- Loading State -->
            <StackPanel Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="52" Height="52" Margin="0,0,0,20"/>
                <TextBlock Text="Discovering servers on the network..."
                           FontSize="15" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="This may take a moment..."
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ViewModel.IsEmpty}" Value="True"/>
                                    <Condition Binding="{Binding ViewModel.IsLoading}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ui:SymbolIcon Symbol="Server24" FontSize="36"
                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No servers discovered" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Make sure ShaPrint servers are running on the LAN."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                <ui:Button Content="Refresh Now"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding ViewModel.RefreshCommand}"
                           Appearance="Primary"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>

            <!-- Filter No Results State -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ViewModel.IsFilterNoResults}" Value="True"/>
                                    <Condition Binding="{Binding ViewModel.IsLoading}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ui:SymbolIcon Symbol="Search24" FontSize="36"
                                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No servers match your filter"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Try adjusting your search criteria."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  Servers List                                        -->
            <!-- ─────────────────────────────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ViewModel.IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ViewModel.IsFilterNoResults}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding ViewModel.FilteredServers}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,0,16"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Server Card -->
                            <ui:Card Padding="0" VerticalAlignment="Top">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- ─────────────────────── -->
                                    <!--  SUMMARY ROW             -->
                                    <!-- ─────────────────────── -->
                                    <Border Grid.Row="0" Padding="18,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.6*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="0"
                                                    Background="{Binding StatusBrush}"
                                                    CornerRadius="20" Padding="12,5"
                                                    Margin="0,0,18,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="White"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Hostname &amp; IP &amp; Version -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <TextBlock Text="{Binding HostName}"
                                                               FontSize="15" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding HostName}"/>
                                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            CornerRadius="4" Padding="5,2" Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding IpAddress}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding IpAddress}"/>
                                            </StackPanel>

                                            <!-- Counts + Channel -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        CornerRadius="4" Padding="6,2"
                                                        HorizontalAlignment="Left" Margin="0,0,0,6"
                                                        ToolTip="Network Channel">
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                        <Run Text="CH: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding NetworkChannel, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" ToolTip="Connected Printers, Scanners, and Active Clients">
                                                    <ui:SymbolIcon Symbol="Print24" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Payload.Printers.Count, FallbackValue=0}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                    <ui:SymbolIcon Symbol="Scan24" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Payload.Scanners.Count, FallbackValue=0}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                    <ui:SymbolIcon Symbol="People24" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Payload.ActiveClients.Count, FallbackValue=0}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Uptime &amp; Last Seen -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <ui:SymbolIcon Symbol="Clock24" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock FontSize="12" VerticalAlignment="Center">
                                                        <Run Text="Uptime: "
                                                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <Run Text="{Binding UptimeText, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Eye24" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock FontSize="12" VerticalAlignment="Center">
                                                        <Run Text="Seen: "
                                                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <Run Text="{Binding LastSeenText, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Expand / Collapse Button -->
                                            <ui:Button Grid.Column="4"
                                                       Command="{Binding DataContext.ViewModel.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Appearance="Secondary"
                                                       VerticalAlignment="Center">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                        <Setter Property="Icon" Value="{ui:SymbolIcon ChevronDown24}"/>
                                                        <Setter Property="Content" Value="Details"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Icon" Value="{ui:SymbolIcon ChevronUp24}"/>
                                                                <Setter Property="Content" Value="Collapse"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                        </Grid>
                                    </Border>

                                    <!-- ─────────────────────── -->
                                    <!--  EXPANDED DETAIL PANEL  -->
                                    <!-- ─────────────────────── -->
                                    <Grid Grid.Row="1"
                                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Divider line -->
                                        <Border Grid.Row="0" Height="1"
                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>

                                        <!-- Error Banner -->
                                        <Border Grid.Row="1"
                                                Margin="18,12,18,0"
                                                CornerRadius="8" Padding="0"
                                                BorderThickness="0"
                                                Visibility="{Binding Payload.Errors.Count, Converter={StaticResource IntToVis}, FallbackValue=Collapsed}">
                                            <DockPanel>
                                                <!-- Left accent bar -->
                                                <Rectangle DockPanel.Dock="Left" Width="4" Fill="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                <!-- Content area -->
                                                <Border Padding="14,10"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        CornerRadius="0,8,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="ErrorCircle24"
                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                                   FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13">
                                                            <Run Text="Recent errors detected — check the "/>
                                                            <Run Text="Errors" FontWeight="Bold"/>
                                                            <Run Text=" tab below."/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DockPanel>
                                        </Border>

                                        <!-- Detail Tabs -->
                                        <TabControl Grid.Row="2" Margin="18,8,18,16" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

                                            <!-- Printers Tab -->
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Print24" FontSize="13" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Printers"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <Border Style="{StaticResource TabContentPanel}">
                                                    <ui:DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HorizontalScrollBarVisibility="Disabled"
                                                              ItemsSource="{Binding Payload.Printers}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Printer Name"
                                                                                Binding="{Binding Name}" Width="4*"/>
                                                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource StatusPill}">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"
                                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTemplateColumn Header="Queue" Width="1*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource StatusPill}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding QueueLength}"
                                                                                           FontSize="12" FontWeight="SemiBold"
                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                                <TextBlock Text=" jobs"
                                                                                           FontSize="11"
                                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                                           Margin="3,0,0,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="Error Description"
                                                                                Binding="{Binding ErrorDescription}" Width="4*"/>
                                                        </DataGrid.Columns>
                                                    </ui:DataGrid>
                                                </Border>
                                            </TabItem>

                                            <!-- Scanners Tab -->
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Scan24" FontSize="13" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Scanners"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <Border Style="{StaticResource TabContentPanel}">
                                                    <ui:DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HorizontalScrollBarVisibility="Disabled"
                                                              ItemsSource="{Binding Payload.Scanners}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Scanner Name"
                                                                                Binding="{Binding Name}" Width="4*"/>
                                                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource StatusPill}">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"
                                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="Last Active"
                                                                                Binding="{Binding LastScanAgo, FallbackValue='N/A'}"
                                                                                Width="2.5*"/>
                                                        </DataGrid.Columns>
                                                    </ui:DataGrid>
                                                </Border>
                                            </TabItem>

                                            <!-- Connected Clients Tab -->
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="People24" FontSize="13" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Connected Clients"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <Border Style="{StaticResource TabContentPanel}">
                                                    <ui:DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HorizontalScrollBarVisibility="Disabled"
                                                              ItemsSource="{Binding Payload.ActiveClients}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Client IP Address"
                                                                                Binding="{Binding Ip}" Width="1*"/>
                                                            <DataGridTextColumn Header="Connected Since"
                                                                                Binding="{Binding ConnectedSince, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                                                Width="1*"/>
                                                        </DataGrid.Columns>
                                                    </ui:DataGrid>
                                                </Border>
                                            </TabItem>

                                            <!-- Job Activity Tab -->
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="ClipboardTaskListLtr24" FontSize="13" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Job Activity"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <Border Style="{StaticResource TabContentPanel}">
                                                    <ui:DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HorizontalScrollBarVisibility="Disabled"
                                                              ItemsSource="{Binding Payload.RecentJobs}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Time"
                                                                                Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                                                Width="1*"/>
                                                            <DataGridTextColumn Header="Type"
                                                                                Binding="{Binding Type}" Width="1*"/>
                                                            <DataGridTextColumn Header="Device"
                                                                                Binding="{Binding PrinterName}" Width="2*"/>
                                                            <DataGridTextColumn Header="Job Title"
                                                                                Binding="{Binding Document}" Width="3*"/>
                                                            <DataGridTextColumn Header="Client IP"
                                                                                Binding="{Binding ClientIp}" Width="1.5*"/>
                                                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource StatusPill}">
                                                                            <TextBlock Text="{Binding Status}" FontSize="12"
                                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </ui:DataGrid>
                                                </Border>
                                            </TabItem>

                                            <!-- Errors Tab -->
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Warning24" FontSize="13" Margin="0,0,6,0"
                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                        <TextBlock Text="Errors"
                                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <Border Style="{StaticResource TabContentPanel}">
                                                    <ui:DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow" CanUserResizeRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HorizontalScrollBarVisibility="Disabled"
                                                              ItemsSource="{Binding Payload.Errors}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Time"
                                                                                Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                                                Width="1*"/>
                                                            <DataGridTextColumn Header="Source"
                                                                                Binding="{Binding Source}" Width="1.5*"/>
                                                            <DataGridTemplateColumn Header="Error Message" Width="5*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="4" Padding="8,3"
                                                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                                HorizontalAlignment="Left">
                                                                            <TextBlock Text="{Binding Message}"
                                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                                                       FontSize="12" TextWrapping="Wrap"
                                                                                       VerticalAlignment="Center"
                                                                                       MaxWidth="400"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </ui:DataGrid>
                                                </Border>
                                            </TabItem>

                                        </TabControl>
                                    </Grid>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
