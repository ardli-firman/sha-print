<Page x:Class="ShaPrint.WpfApp.Views.Pages.ServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Server Dashboard">

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="3*"/>   <!-- Printer List -->
            <RowDefinition Height="Auto"/> <!-- Controls bar -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="Auto"/> <!-- Log label -->
            <RowDefinition Height="2*"/>   <!-- Logs -->
        </Grid.RowDefinitions>

        <!-- Header (top) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Server Dashboard" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Select printers and scanners to expose to the network:" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Exposed Devices (side by side) -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Printers -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Exposed Printers" Margin="0,0,0,4" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ListBox ItemsSource="{Binding ViewModel.Printers}" 
                         IsEnabled="{Binding ViewModel.IsNotRunning}"
                         BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,0"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2,1" Padding="4,0"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right: Scanners -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Exposed Scanners" Margin="0,0,0,4" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ListBox ItemsSource="{Binding ViewModel.Scanners}" 
                         IsEnabled="{Binding ViewModel.IsNotRunning}"
                         BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,0"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2,1" Padding="4,0"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- Controls bar (bottom) -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding ViewModel.StatusText}" 
                       VerticalAlignment="Center" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsRunning}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ui:Button Grid.Column="1" 
                       Command="{Binding ViewModel.ToggleServerCommand}"
                       Content="{Binding ViewModel.ToggleButtonText}"
                       Appearance="{Binding ViewModel.ToggleButtonAppearance}" />
        </Grid>

        <!-- Activity Log label (bottom) -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Transparent" Margin="0,5"/>

        <TextBlock Grid.Row="4" Text="Activity Log (Resizable &amp; Copyable):" Margin="0,0,0,3" 
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>

        <!-- Activity Log (bottom, compact) -->
        <TextBox Grid.Row="5" Text="{Binding ViewModel.LogsText, Mode=OneWay}" 
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                 FontFamily="Consolas" FontSize="11"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />

    </Grid>
</Page>
