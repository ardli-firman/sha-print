<Page x:Class="ShaPrint.WpfApp.Views.Pages.ServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Server Dashboard">

    <DockPanel Margin="24,20,24,16" LastChildFill="True">

        <!-- Header (top) -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Server Dashboard" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Select printers to expose to the network:" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Controls bar (bottom) -->
        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding ViewModel.StatusText}" 
                       VerticalAlignment="Center" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsRunning}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ui:Button Grid.Column="1" 
                       Command="{Binding ViewModel.ToggleServerCommand}"
                       Content="{Binding ViewModel.ToggleButtonText}"
                       Appearance="{Binding ViewModel.ToggleButtonAppearance}" />
        </Grid>

        <!-- Activity Log label (bottom) -->
        <TextBlock DockPanel.Dock="Bottom" Text="Activity Log:" Margin="0,10,0,3" 
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>

        <!-- Activity Log (bottom, compact) -->
        <ListBox DockPanel.Dock="Bottom" ItemsSource="{Binding ViewModel.Logs}" 
                 FontFamily="Consolas" FontSize="11" Height="110"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,1"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Printer List (fills remaining space, compact items) -->
        <ListBox ItemsSource="{Binding ViewModel.Printers}" 
                 IsEnabled="{Binding ViewModel.IsNotRunning}"
                 BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="2,0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2,1" Padding="4,0"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Page>
