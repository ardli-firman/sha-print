<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- ─────────────────────────────────────────────
       Build-time PSK injection from GitHub Actions
       Set via:  dotnet build -p:ShaPrintPsk="key"
       Or env:   SHA_PRINT_PSK env var
       ───────────────────────────────────────────── -->
  <Target Name="InjectBuildTimePsk" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <_Psk>$(ShaPrintPsk)</_Psk>
      <_Psk Condition="'$(_Psk)' == ''">$(SHA_PRINT_PSK)</_Psk>
    </PropertyGroup>

    <!-- Generate secret file into obj/ (gitignored, safe) -->
    <WriteLinesToFile
      Condition="'$(_Psk)' != ''"
      File="$(IntermediateOutputPath)BuildTimeSecrets.g.cs"
      Lines="// AUTO-GENERATED at build time.&#xd;&#xa;namespace ShaPrint.Core&#xd;&#xa;{&#xd;&#xa;    internal static class BuildTimeSecrets&#xd;&#xa;    {&#xd;&#xa;        internal const string Psk = &quot;$(_Psk)&quot;;&#xd;&#xa;    }&#xd;&#xa;}"
      Overwrite="true" />

    <!-- Swap: use generated (with key) instead of committed stub (empty) -->
    <ItemGroup Condition="'$(_Psk)' != ''">
      <Compile Remove="BuildTimeSecrets.cs" />
      <Compile Include="$(IntermediateOutputPath)BuildTimeSecrets.g.cs" />
    </ItemGroup>
  </Target>

</Project>
